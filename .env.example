# ── Supabase (required) ────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe (required for payments) ────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PREMIUM_PRICE_ID=price_xxx

# ── Groq (required for AI analysis + travel intel + pack analysis) ────────────
GROQ_API_KEY=gsk_...

# ── Anthropic / Claude (required for AI guides) ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── RapidAPI / Skyscanner (required for flight scanning) ─────────────────────
RAPIDAPI_KEY=your-rapidapi-key

# ── SerpAPI / Google Flights (optional, for price insights) ──────────────────
SERPAPI_KEY=your-serpapi-key

# ── Unsplash (optional, for destination images) ─────────────────────────────
UNSPLASH_ACCESS_KEY=your-unsplash-key

# ── Resend (required for email alerts) ──────────────────────────────────────
RESEND_API_KEY=re_...

# ── Cron protection (required for cron endpoints) ───────────────────────────
CRON_SECRET=your-random-secret-string

# ── Site URL ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://geai-mon-vol.vercel.app
NEXT_PUBLIC_APP_URL=https://geaimonvol.com

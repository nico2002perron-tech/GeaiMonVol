{
    "functions": {
        "src/app/api/cron/scan-prices/route.ts": {
            "maxDuration": 60
        },
        "src/app/api/cron/send-alerts/route.ts": {
            "maxDuration": 60
        },
        "src/app/api/cron/aggregate-daily/route.ts": {
            "maxDuration": 60
        },
        "src/app/api/cron/weekly-digest/route.ts": {
            "maxDuration": 60
        }
    },
    "crons": [
        {
            "path": "/api/cron/scan-prices",
            "schedule": "0 8 * * *"
        },
        {
            "path": "/api/cron/aggregate-daily",
            "schedule": "30 8 * * *"
        },
        {
            "path": "/api/cron/send-alerts",
            "schedule": "0 9 * * *"
        },
        {
            "path": "/api/cron/weekly-digest",
            "schedule": "0 14 * * 1"
        }
    ]
}
